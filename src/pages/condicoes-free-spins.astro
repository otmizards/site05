---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config/site.js";

const title = `Condições das Rodadas Grátis — ${SITE.name ?? SITE.siteName}`;
const description = "O que verificar nas condições: slot elegível, valor por rodada, wagering, prazos e limites.";
const TELEGRAM_URL = SITE.telegram ?? SITE.telegramUrl;
---

<BaseLayout title={title} description={description} canonicalPath="/condicoes-free-spins">
  <main class="container" style="padding: 32px 0;">
    <h1>Condições das rodadas grátis: o que verificar</h1>

    <h2>Checklist rápido</h2>
    <ul>
      <li><strong>Slot elegível</strong> e se podes mudar de slot.</li>
      <li><strong>Valor por rodada</strong> (ex.: €0,10/€0,20).</li>
      <li><strong>Wagering</strong> aplicado aos ganhos (se existir).</li>
      <li><strong>Prazo</strong> para usar as rodadas e prazo para levantar ganhos.</li>
      <li><strong>Limites</strong> (cap) quando aplicável.</li>
    </ul>

    <p style="margin-top:24px;">
      <a class="btn btn-primary" href={TELEGRAM_URL} target="_blank" rel="noopener noreferrer">
        Receber ofertas ativas no Telegram
      </a>
    </p>

    <p style="margin-top:20px;">
      Próximo guia: <a href="/erros-comuns">Erros comuns</a> ·
      <a href="/o-que-sao-rodadas-gratis">O que são rodadas grátis</a> ·
      <a href="/">Voltar à homepage</a>
    </p>
  </main>
</BaseLayout>
