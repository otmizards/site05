---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config/site.js";

const title = `O que são Rodadas Grátis — ${SITE.name ?? SITE.siteName}`;
const description = "Definição simples, onde se aplicam e como funcionam na prática em casinos online.";
const TELEGRAM_URL = SITE.telegram ?? SITE.telegramUrl;
---

<BaseLayout title={title} description={description} canonicalPath="/o-que-sao-rodadas-gratis">
  <main class="container" style="padding: 32px 0;">
    <h1>O que são rodadas grátis</h1>
    <p>
      Rodadas grátis (free spins) são giros oferecidos para slots específicas. Em muitos casos, os ganhos ficam sujeitos
      a regras próprias (ex.: wagering, prazos ou limites).
    </p>

    <h2>Como funcionam</h2>
    <ul>
      <li>Recebes um número de rodadas para uma slot elegível.</li>
      <li>Cada rodada tem um valor (fixo ou variável).</li>
      <li>Os ganhos podem ir para um saldo promocional.</li>
    </ul>

    <p style="margin-top:24px;">
      <a class="btn btn-primary" href={TELEGRAM_URL} target="_blank" rel="noopener noreferrer">
        Entrar no Telegram e ver atualizações
      </a>
    </p>

    <p style="margin-top:20px;">
      Próximo guia: <a href="/condicoes-free-spins">Condições e regras</a> ·
      <a href="/">Voltar à homepage</a>
    </p>
  </main>
</BaseLayout>
