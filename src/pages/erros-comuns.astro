---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config/site.js";

const title = `Erros Comuns com Rodadas Grátis — ${SITE.name ?? SITE.siteName}`;
const description = "Os erros mais frequentes e como evitar perder ofertas por prazos, regras e jogos não elegíveis.";
const TELEGRAM_URL = SITE.telegram ?? SITE.telegramUrl;
---

<BaseLayout title={title} description={description} canonicalPath="/erros-comuns">
  <main class="container" style="padding: 32px 0;">
    <h1>Erros comuns com rodadas grátis</h1>

    <ul>
      <li><strong>Deixar expirar</strong>: muitas ofertas têm prazo curto.</li>
      <li><strong>Ignorar regras</strong>: ganhos podem ficar bloqueados por wagering.</li>
      <li><strong>Assumir que vale para tudo</strong>: normalmente é só para slots específicas.</li>
      <li><strong>Não verificar limites</strong>: alguns bónus têm cap de levantamento.</li>
    </ul>

    <p style="margin-top:24px;">
      <a class="btn btn-primary" href={TELEGRAM_URL} target="_blank" rel="noopener noreferrer">
        Entrar no Telegram
      </a>
    </p>

    <p style="margin-top:20px;">
      Voltar: <a href="/condicoes-free-spins">Condições</a> · <a href="/">Homepage</a>
    </p>
  </main>
</BaseLayout>
